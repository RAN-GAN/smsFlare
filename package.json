{
    "name": "smsflare",
    "version": "0.1.0",
    "description": "Distributed SMS Gateway Platform with Cloudflare Workers",
    "main": "src/backend/index.js",
    "type": "module",
    "scripts": {
        "dev": "wrangler dev --local",
        "deploy": "wrangler deploy",
        "migrations:create": "wrangler migrations create",
