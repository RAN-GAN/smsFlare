        "migrations:status": "wrangler d1 migrations status smsflare"
    },
    "dependencies": {
        "hono": "^4.0.0",
        "wrangler": "^3.50.0"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260511.1"
    }
}
